# Echo Barrier Hub — environment template.
# Copy to .env.local and fill with the ROTATED keys. NEVER commit .env.local.
#
# Supabase (ops project "Hubspot Shipping and Stocks" — korylyniwsqtsvzuzydg).
# The anon/publishable key is the ONLY Supabase key that may reach the browser.
NEXT_PUBLIC_SUPABASE_URL=https://korylyniwsqtsvzuzydg.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Server-side ONLY. Bypasses RLS — never expose to the client, never commit.
SUPABASE_SERVICE_ROLE_KEY=

# HubSpot private-app token (server-side only). Used by the quote flow.
HUBSPOT_ACCESS_TOKEN=
# HubSpot portal/account id — used only to deep-link to a deal after quote upload.
NEXT_PUBLIC_HUBSPOT_PORTAL_ID=

# n8n (Dave's stock + invite workflows). Server-side only.
N8N_ECHOBARRIER_API_KEY=
N8N_INVITE_WEBHOOK_URL=
