# Echo Barrier Hub — environment template.
# Copy to .env.local and fill with the ROTATED keys. NEVER commit .env.local.
#
# Supabase (ops project "Hubspot Shipping and Stocks" — korylyniwsqtsvzuzydg).
# The anon/publishable key is the ONLY Supabase key that may reach the browser.
NEXT_PUBLIC_SUPABASE_URL=https://korylyniwsqtsvzuzydg.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Server-side ONLY. Bypasses RLS — never expose to the client, never commit.
SUPABASE_SERVICE_ROLE_KEY=

# HubSpot private-app token (server-side only). Used by the quote flow.
HUBSPOT_ACCESS_TOKEN=
# HubSpot portal/account id — used only to deep-link to a deal after quote upload.
NEXT_PUBLIC_HUBSPOT_PORTAL_ID=

# n8n (Dave's stock + invite workflows). Server-side only.
N8N_ECHOBARRIER_API_KEY=
N8N_INVITE_WEBHOOK_URL=

# Manufacturing Supabase project (mfg "BOM/landed-cost/FX" — cdkpczinzhykcdbfoobn).
# Read-only, SERVER-SIDE only (BOM module). RLS is service-role-only on that project.
MFG_SUPABASE_URL=https://cdkpczinzhykcdbfoobn.supabase.co
MFG_SUPABASE_SERVICE_ROLE_KEY=

# Cargo Partner (Transport module — shipment lookup). Server-side only. ROTATE before use.
CARGO_PARTNER_USERNAME=
CARGO_PARTNER_PASSWORD=
CARGO_PARTNER_CLIENT_ID=
CARGO_PARTNER_CLIENT_SECRET=

# E2E (Playwright) — a Supabase auth user the tests log in as. Needs a profile +
# capabilities to exercise gated modules.
E2E_USERNAME=
E2E_PASSWORD=
# Optional: a SCOPED (quotes-only) user → activates the negative-gating specs.
# Your existing non-admin already fits (quotes.view + quotes.create only).
E2E_LIMITED_USERNAME=
E2E_LIMITED_PASSWORD=
# Optional: a real HubSpot deal id in the test user's pipeline → activates the
# read-only Quotes specs (also needs HUBSPOT_ACCESS_TOKEN above). Never submitted.
E2E_DEAL_ID=
